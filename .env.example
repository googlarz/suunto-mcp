# Suunto OAuth app credentials — get these from https://apizone.suunto.com
SUUNTO_CLIENT_ID=
SUUNTO_CLIENT_SECRET=
SUUNTO_SUBSCRIPTION_KEY=

# Where the OAuth callback lands during pairing.
# Must match the redirect URI you registered in the Suunto developer portal.
SUUNTO_REDIRECT_URI=http://localhost:8421/callback

# Where to store the encrypted token bundle (defaults to ~/.suunto-mcp/tokens.json)
SUUNTO_TOKEN_PATH=
